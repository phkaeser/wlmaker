      HighlightedTextColor = "argb32:ff000000";
      DisabledTextColor = "argb32:ff808080";
      Height = 31;
      BezelWidth = 1;
      Width = 212;
    };
  };
  TaskList = {
    Fill = {
      Color = "argb32:c0202020";
      Type = SOLID;
    };
    Font = {
      Face = Helvetica;
      Weight = Bold;
      Size = 25;
    };
    TextColor = "argb32:ffffffff";
  };
