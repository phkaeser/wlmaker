// Inspired by the 'Debian' theme of Window Maker.
{
  Name = "Debian (1.41x)";
  BackgroundColor = "argb32:ff77aac4";
  Cursor = {
    Name = default;
    Size = 34;
  };
  Dock = {
    Margin = {
      Width = 1;
      Color = "argb32:ff000000";
    };
  };
  Tile = {
    Size = 90;
    ContentSize = 79;
    BezelWidth = 3;
    Fill = {
      From = "argb32:ffa6a6b6";
      To = "argb32:ff515561";
      Type = DGRADIENT;
    };
  };
  Clip = {
    Font = {
      Face = Helvetica;
      Weight = Bold;
      Size = 17;
    };
    TextColor = "argb32:ff000000";
  };
  Window = {
    TitleBar = {
      FocussedFill = {
        From = "argb32:ff505a5e";
        To = "argb32:ff202a2e";
        Type = DGRADIENT;
      };
      FocussedTextColor = "argb32:ffffffff";
      BlurredFill = {
        From = "argb32:ffc2c0c5";
        To = "argb32:ff828085";
        Type = DGRADIENT;
      };
      BlurredTextColor = "argb32:ff000000";
      Height = 31;
      BezelWidth = 1;
      Margin = {
        Width = 1;
        Color = "argb32:ff000000" ;
      };
      Font = {
        Face = Helvetica;
        Weight = Bold;
        Size = 21;
      };
    };
    ResizeBar = {
      Fill = {
        Color = "argb32:ffc2c0c5";
        Type = SOLID;
      };
      Height = 10;
      CornerWidth = 41;
      BezelWidth = 1;
    };
    Border = {
      Width = 1;
      Color = "argb32:ff000000";
