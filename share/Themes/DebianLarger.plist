    Margin = {
      Width = 1;
      Color = "argb32:ff000000";
    };
  };
  Menu = {
    Margin = {
      Width = 1;
      Color = "argb32:ff000000";
    };
    Border = {
      Width = 1;
      Color = "argb32:ff000000";
    };
    Item = {
      Fill = {
        From = "argb32:ffc2c0c5";
        To = "argb32:ff828085";
        Type = DGRADIENT;
      };
      HighlightedFill = {
        Color = "argb32:ffffffff";
        Type = SOLID;
      };
      Font = {
        Face = Helvetica;
        Weight = Normal;
        Size = 20;
