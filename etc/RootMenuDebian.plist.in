// Definition of root menu, for Debian with wlmtool.
("Root Menu",
 //! [wlmtool]
 ("Applications...",
  GeneratePlistMenu,
  "@PROJECT_BINARY_DIR@/tool/wlmtool genmenu @PROJECT_BINARY_DIR@/share"),
 ("Appearance...",
  GeneratePlistMenu,
  "@PROJECT_BINARY_DIR@/tool/wlmtool GenerateThemesMenu @PROJECT_SOURCE_DIR@/share/Themes"),
 //! [wlmtool]
 ("Workspaces...",
  ("New", WorkspaceAdd),
  ("Destroy Last", WorkspaceDestroyLast),
  ("Go To Previous", WorkspacePrevious),
  ("Go To Next", WorkspaceNext)),
 ("Lock", LockScreen),
 (Exit, Quit))
